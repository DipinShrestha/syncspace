# multer-storage-cloudinary@4.0.0 declares a peer dependency on cloudinary@^1.21.0,
# but its code actually works fine with cloudinary@^2.x (it imports via the
# universal `require('cloudinary').v2` path). The peer-dep range in its
# package.json was just never updated upstream (see
# https://github.com/affanshahid/multer-storage-cloudinary/issues/53).
# This setting tells npm to install anyway instead of failing the build.
legacy-peer-deps=true